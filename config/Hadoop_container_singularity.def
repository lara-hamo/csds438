Bootstrap: docker
From: python:3.10-slim

%labels
    Authors 
    Version v1.0
    Description "Hadoop Streaming Text Preprocessing with/without N-grams"

%help
    This container runs a Hadoop Streaming pipeline for large-scale
    text preprocessing and N-gram analysis. It includes:
    - Python 3 environment
    - Mapper and Reducer scripts
    - Stopword filtering
    - N-gram generation (unigram, bigram, trigram)

%files
    mapper.py        /app/mapper.py
    reducer.py       /app/reducer.py
    stopwords.txt    /app/stopwords.txt

%post
    # Update system and install minimal dependencies
    apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        ca-certificates \
        && rm -rf /var/lib/apt/lists/*

    # Upgrade pip
    pip install --no-cache-dir --upgrade pip

    # (Optional) Install NLP libraries if needed
    # pip install nltk

    # Ensure scripts are executable
    chmod +x /app/mapper.py
    chmod +x /app/reducer.py

    apt-get install -y default-jdk wget tar

    wget https://archive.apache.org/dist/hadoop/common/hadoop-3.3.6/hadoop-3.3.6.tar.gz
    tar -xzf hadoop-3.3.6.tar.gz -C /opt/
    mv /opt/hadoop-3.3.6 /opt/hadoop
    rm hadoop-3.3.6.tar.gz

%environment
    # Set working directory
    export APP_HOME=/app
    export PATH=$APP_HOME:$PATH
    export PYTHONUNBUFFERED=1

    export JAVA_HOME=/usr/lib/jvm/default-java
    export HADOOP_HOME=/opt/hadoop
    export PATH=$HADOOP_HOME/bin:$HADOOP_HOME/sbin:$PATH

%runscript
    # Default execution (can be overridden)
    echo "Running Hadoop Streaming task..."
    exec "$@"

%test
    # Simple test to verify container works
    echo "Testing mapper..."
    echo "The quick brown fox jumps over the lazy dog" | python3 /app/mapper.py